          <SubComponents>
            <Component class="javax.swing.JTextArea" name="jTextArea1">
              <Properties>
                <Property name="columns" type="int" value="20"/>
                <Property name="rows" type="int" value="5"/>
                <Property name="text" type="java.lang.String" value="1. Calon pendaki wajib melakukan &#xa;    registrasi online maksimal H-3 &#xa;    sebelum hari pelaksanaan &#xa;    pendakian.&#xa;&#xa;2. Batas usia minimal pendaki &#xa;    adalah 17 tahun. Pendaki di &#xa;    bawah 17 tahun wajib &#xa;    menyertakan Surat Izin Orang &#xa;    Tua/Wali dan didampingi &#xa;    pemandu.&#xa;&#xa;3. Kuota pendakian harian bersifat &#xa;    terbatas; tiket yang sudah dibeli &#xa;    tidak dapat dibatalkan atau &#xa;    dialihkan tanggalnya.&#xa;&#xa;4. Setiap pendaki wajib membawa &#xa;    Kartu Identitas (KTP/SIM/Paspor)&#xa;    asli yang sesuai dengan data &#xa;    saat registrasi online."/>
              </Properties>
            </Component>
          </SubComponents>
        </Container>
        <Component class="javax.swing.JLabel" name="jLabel9">
          <Properties>
            <Property name="text" type="java.lang.String" value="Ketentuan"/>
          </Properties>
        </Component>
      </SubComponents>
    </Container>
